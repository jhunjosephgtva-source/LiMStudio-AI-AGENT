# Supabase (already provisioned for you — see README for the actual values)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Anthropic API key — get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: override the default model (defaults to claude-sonnet-5)
ANTHROPIC_MODEL=claude-sonnet-5

# Password required to unlock admin mode (add/edit/delete/upload processes)
# Pick your own value — do not reuse a password you use elsewhere.
ADMIN_PASSWORD=

# Optional: separate secret used to sign the admin session cookie.
# If omitted, ADMIN_PASSWORD is used for this too — fine for this project's scale.
SESSION_SECRET=
